# =============================================
# LeadTrack AI — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# =============================================

# ---- Supabase ----
# From: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ---- EmailJS ----
# From: https://emailjs.com → Account → API Keys
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ---- App Base URL ----
# Used to generate tracking links (update after Vercel deploy)
VITE_APP_URL=http://localhost:5173

# ---- Optional: Gemini AI ----
# For AI-powered lead classification (leave blank to use rule-based)
VITE_GEMINI_API_KEY=
